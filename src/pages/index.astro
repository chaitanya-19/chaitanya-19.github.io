---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import PaperCard from "@/components/PaperCard.astro";
import HeroSection from "@/components/HeroSection.astro";
import LinkButton from "@/components/LinkButton.astro";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import getSortedPosts from "@/utils/getSortedPosts";

const posts = await getCollection("blog");
const recentPosts = getSortedPosts(posts).slice(0, 3);

const allProjects = await getCollection("projects", ({ data }) => !data.draft);
allProjects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredProjects = allProjects.filter(p => p.data.featured);
const displayProjects = (featuredProjects.length > 0 ? featuredProjects : allProjects).slice(0, 3);

const allPapers = await getCollection("papers", ({ data }) => !data.draft);
allPapers.sort((a, b) => b.data.year - a.data.year);
const featuredPapers = allPapers.filter(p => p.data.featured);
const displayPapers = (featuredPapers.length > 0 ? featuredPapers : allPapers).slice(0, 2);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <HeroSection />

    {
      displayProjects.length > 0 && (
        <section
          id="featured-projects"
          class:list={["pt-12 pb-6", "border-b border-border"]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Projects</h2>
          <ul>
            {displayProjects.map(project => (
              <ProjectCard {...project} />
            ))}
          </ul>
          <div class="mt-2 text-right">
            <LinkButton href="/projects">
              All Projects
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section
          id="recent-posts"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": displayPapers.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Blogs</h2>
          <ul>
            {recentPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
          <div class="mt-2 text-right">
            <LinkButton href="/posts">
              All Posts
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        </section>
      )
    }

    {
      displayPapers.length > 0 && (
        <section id="featured-papers" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">Papers</h2>
          <ul>
            {displayPapers.map(paper => (
              <PaperCard {...paper} />
            ))}
          </ul>
          <div class="mt-2 text-right">
            <LinkButton href="/papers">
              All Papers
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
